{"cells":[{"cell_type":"code","source":[" youimportyouimportimportyouimportyouimportimportimport toimportimport sys\n","import osososososos\n","import subprocess\n","import platform\n","import json\n","import time\n","import threading\n","from PyQt6.QtWidgets import (\n","    QApplication, QMainWindow, QWidget, QVBoxLayout, QHBoxLayout,\n","    QTextEdit, QLineEdit, QPushButton, QLabel, QFrame, QScrollArea\n",")\n","from PyQt6.QtCore import Qt, pyqtSignal, QObject\n","from PyQt6.QtGui import QFont, QColor, QPalette\n","import google.generativeai as genai\n","\n","# --- CONFIGURATIOCONFIGURATIONN ---\n","api_key = \"\"\n","genai.configure(api_key=api_key)\n","model = genai.GenerativeModel('gemini-2.5-flash-preview-09-2025')\n","SigpyqtSignalSigpyqtSignalSigpyqtSignalSigpyqtSignal\n","class WorkerSignSigpyqtSignalWorkerSignSigpyqtSignal\n","    \"\"\";hreadhreadhreadhread communication.\"\"\"\n","    response_ready =hreadhreadtSignalyqtSignaltSignalyqtSignal(dict)\n","    log_message = pyqtSignal(str)\n","\n","class AIAgentGUI(QMainWindow):\n","    def __init__(self):\n","        super().__init__()\n","        self.setWindowTitle(\"AI Command Center - Linux Desktop Agent\")\n","        self.resize(1100, 700)\n","        self.signals = WorkerSignals()\n","        self.signals.response_ready.connect(self.handle_ai_response)\n","        self.signals.log_message.connect(self.append_log)\n","\n","        self.init_ui()\n","        self.append_log(\"System initialized. Waiting for commands...\")\n","\n","    def init_ui(self):\n","        # Main Layout\n","        central_widget = QWidget()\n","        self.setCentralWidget(central_widget)\n","        main_layout = QHBoxLayout(central_widget)\n","\n","        # --- LEFT PANEL: AI Chat ---\n","        left_panel = QVBoxLayout()\n","\n","        chat_label = QLabel(\"AI CO-PILOT INTERFACE\")\n","        chat_label.setFont(QFont(\"Monospace\", 12, QFont.Weight.Bold))\n","        left_panel.addWidget(chat_label)\n","\n","        self.chat_display = QTextEdit()\n","        self.chat_display.setReadOnly(True)\n","        self.chat_display.setStyleSheet(\"background-color: #1e1e1e; color: #d4d4d4; border-radius: 5px; padding: 10px;\")\n","        left_panel.addWidget(self.chat_display)\n","\n","        input_area = QHBoxLayout()\n","        self.user_input = QLineEdit()\n","        self.user_input.setPlaceholderText(\"Ask the agent to open apps, read files, or run commands...\")\n","        self.user_input.setStyleSheet(\"padding: 8px; background-color: #2d2d2d; color: white; border: 1px solid #3e3e3e;\")\n","        self.user_input.returnPressed.connect(self.send_to_ai)\n","\n","        self.send_btn = QPushButton(\"EXECUTE\")\n","        self.send_btn.setStyleSheet(\"background-color: #007acc; color: white; padding: 8px 15px; font-weight: bold;\")\n","        self.send_btn.clicked.connect(self.send_to_ai)\n","\n","        input_area.addWidget(self.user_input)\n","        input_area.addWidget(self.send_btn)\n","        left_panel.addLayout(input_area)\n","\n","        # --- RIGHT PANEL: System Logs & Stats ---\n","        right_panel = QVBoxLayout()\n","\n","        log_label = QLabel(\"SYSTEM ACTIVITY LOG\")\n","        log_label.setFont(QFont(\"Monospace\", 10, QFont.Weight.Bold))\n","        right_panel.addWidget(log_label)\n","\n","        self.log_display = QTextEdit()\n","        self.log_display.setReadOnly(True)\n","        self.log_display.setFont(QFont(\"Monospace\", 9))\n","        self.log_display.setStyleSheet(\"background-color: #000000; color: #00ff00; border: 1px solid #333;\")\n","        right_panel.addWidget(self.log_display)\n","\n","        # Quick Actions\n","        actions_label = QLabel(\"QUICK CONTROL\")\n","        right_panel.addWidget(actions_label)\n","\n","        btn_layout = QHBoxLayout()\n","        term_btn = QPushButton(\"Open Terminal\")\n","        term_btn.clicked.connect(lambda: self.open_app(\"gnome-terminal\"))\n","        folder_btn = QPushButton(\"Home Dir\")\n","        folder_btn.clicked.connect(lambda: self.execute_cmd(\"ls -la ~\"))\n","\n","        btn_layout.addWidget(term_btn)\n","        btn_layout.addWidget(folder_btn)\n","        right_panel.addLayout(btn_layout)\n","\n","        # Combine Panels\n","        main_layout.addLayout(left_panel, 3)\n","        main_layout.addLayout(right_panel, 1)\n","\n","    # --- SYSTEM LOGIC ---\n","    def append_log(self, text):\n","        timestamp = time.strftime(\"%H:%M:%S\")\n","        self.log_display.append(f\"[{timestamp}] {text}\")\n","\n","    def send_to_ai(self):\n","        text = self.user_input.text().strip()\n","        if not text: return\n","\n","        self.chat_display.append(f\"<b>User:</b> {text}\")\n","        self.user_input.clear()\n","        self.append_log(f\"Querying AI: {text[:30]}...\")\n","\n","        # Run AI request in a separate thread to keep UI responsive\n","        threading.Thread(target=self.process_ai_thread, args=(text,), daemon=True).start()\n","\n","    def process_ai_thread(self, prompt):\n","        system_prompt = \"\"\"\n","        You are a Linux System Agent. Respond ONLY in JSON.\n","        Actions: \"read\" (path), \"cmd\" (command), \"open\" (app), \"talk\" (text).\n","        Format: {\"action\": \"...\", \"target\": \"...\"}\n","        \"\"\"\n","        retries = 5\n","        for i in range(retries):\n","            try:\n","                response = model.generate_content(\n","                    contents=[{\"parts\": [{\"text\": prompt}]}],\n","                    generationConfig={\"responseMimeType\": \"application/json\"},\n","                    systemInstruction={\"parts\": [{\"text\": system_prompt}]}\n","                )\n","                data = json.loads(response.text)\n","                self.signals.response_ready.emit(data)\n","                return\n","            except Exception as e:\n","                time.sleep(2**i)\n","        self.signals.log_message.emit(\"AI Service error.\")\n","\n","    def handle_ai_response(self, data):\n","        action = data.get(\"action\")\n","        target = data.get(\"target\") or data.get(\"path\") or data.get(\"command\") or data.get(\"app\")\n","\n","        if action == \"talk\":\n","            self.chat_display.append(f\"<b>Agent:</b> {data.get('text')}\")\n","        elif action == \"cmd\":\n","            self.chat_display.append(f\"<i>Executing Command: {target}</i>\")\n","            output = self.execute_cmd(target)\n","            self.chat_display.append(f\"<pre style='color: #888;'>{output}</pre>\")\n","        elif action == \"open\":\n","            self.chat_display.append(f\"<i>Launching application: {target}</i>\")\n","            self.open_app(target)\n","        elif action == \"read\":\n","            self.chat_display.append(f\"<i>Reading file: {target}</i>\")\n","            content = self.read_file(target)\n","            self.chat_display.append(f\"<pre style='color: #888;'>{content}</pre>\")\n","\n","    def execute_cmd(self, command):\n","        self.signals.log_message.emit(f\"CMD: {command}\")\n","        try:\n","            result = subprocess.run(command, shell=True, capture_output=True, text=True)\n","            return result.stdout if result.stdout else result.stderr\n","        except Exception as e:\n","            return str(e)\n","\n","    def open_app(self, app):\n","        self.signals.log_message.emit(f\"OPEN: {app}\")\n","        try:\n","            subprocess.Popen([app], stderr=subprocess.DEVNULL, stdout=subprocess.DEVNULL)\n","            return True\n","        except:\n","            # Fallback for generic 'start' if app name is vague\n","            subprocess.Popen([\"xdg-open\", \".\"], shell=False)\n","\n","    def read_file(self, path):\n","        self.signals.log_message.emit(f\"READ: {path}\")\n","        try:\n","            with open(os.path.expanduser(path), 'r') as f:\n","                return f.read(2000) # Limit read for GUI\n","        