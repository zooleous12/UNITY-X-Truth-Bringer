{
  "📝": "4D Calculator App",
  "🔢": "v1.0",
  "👤": "${USER_NAME}",
  
  "⚙️": {
    "➕": {"📝": "add", "🔧": "lambda a,b: a+b"},
    "➖": {"📝": "subtract", "🔧": "lambda a,b: a-b"},
    "✖️": {"📝": "multiply", "🔧": "lambda a,b: a*b"},
    "➗": {"📝": "divide", "🔧": "lambda a,b: a/b if b!=0 else 💀"}
  },
  
  "🎯": {
    "🔵": {"📝": "calculate", "⚡": "📝+🔧+📊"},
    "🟡": {"📝": "validate", "⚡": "🔍+✅"},
    "🔴": {"📝": "error", "⚡": "🚨+💀"}
  },
  
  "📊": {
    "📥": [10, 5],
    "🎭": "➕",
    "📤": 💡
  },
  
  "💡": "📊[📥][0] ⚙️[📊[🎭]][🔧] 📊[📥][1]",
  
  "🔄": {
    "🟢": "📤 = 💡",
    "🔵": "📤 = eval(💡)",
    "🟡": "print(🔵+📤)",
    "🔴": "return 📤"
  }
}
